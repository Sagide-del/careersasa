{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && npm install && npm rebuild sqlite3"
  },
  "deploy": {
    "startCommand": "cd backend && node dist/index.js",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
